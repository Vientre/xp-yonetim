// XP Management - Çok İşletmeli Yönetim Sistemi
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN    // Yönetici
  MANAGER  // Müdür
  STAFF    // Personel
}

enum SalaryType {
  MONTHLY
  HOURLY
  DAILY
}

enum ShiftType {
  NORMAL
  HALF_DAY
  FULL_DAY
  CUSTOM
}

enum PaymentMethod {
  CASH
  CARD
  TICKET
  MIXED
}

enum ClosingStatus {
  OPEN
  CLOSED
  NEEDS_REVIEW
}

enum LogAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  RESTORE
  EXPORT
  APPROVE
  REJECT
}

// ─── KULLANICI ────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  phone        String?
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  businessAccess    UserBusinessAccess[]
  dailyClosings     DailyClosing[]
  mealOrders        MealOrder[]
  attendanceRecords AttendanceRecord[]
  activityLogs      ActivityLog[]       @relation("UserLogs")
  employee          Employee?           @relation("UserEmployee")

  @@map("users")
}

model UserBusinessAccess {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  grantedAt  DateTime @default(now())
  grantedBy  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("user_business_access")
}

// ─── İŞLETMELER ──────────────────────────────────────────────────────────────

model Business {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  address     String?
  phone       String?
  taxNumber   String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  userAccess          UserBusinessAccess[]
  dailyClosings       DailyClosing[]
  mealOrders          MealOrder[]
  employeeAssignments EmployeeBusinessAssignment[]
  attendanceRecords   AttendanceRecord[]
  activityLogs        ActivityLog[]

  @@map("businesses")
}

// ─── GİDER KATEGORİLERİ ──────────────────────────────────────────────────────

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  color     String?   @default("#6366f1")
  icon      String?
  isActive  Boolean   @default(true)
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  expenses ExpenseEntry[]

  @@map("expense_categories")
}

// ─── GÜNLÜK KAPANIŞ ──────────────────────────────────────────────────────────

model DailyClosing {
  id           String        @id @default(cuid())
  businessId   String
  date         DateTime      @db.Date
  status       ClosingStatus @default(OPEN)
  cashIncome   Decimal       @default(0) @db.Decimal(12, 2)
  cardIncome   Decimal       @default(0) @db.Decimal(12, 2)
  ticketIncome Decimal       @default(0) @db.Decimal(12, 2)
  totalIncome  Decimal       @default(0) @db.Decimal(12, 2)
  totalExpense Decimal       @default(0) @db.Decimal(12, 2)
  netAmount    Decimal       @default(0) @db.Decimal(12, 2)
  notes        String?
  isLocked     Boolean       @default(false)
  enteredById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  business  Business      @relation(fields: [businessId], references: [id])
  enteredBy User          @relation(fields: [enteredById], references: [id])
  expenses  ExpenseEntry[]

  @@unique([businessId, date])
  @@map("daily_closings")
}

// ─── GİDER KAYITLARI ─────────────────────────────────────────────────────────

model ExpenseEntry {
  id             String        @id @default(cuid())
  dailyClosingId String
  categoryId     String
  amount         Decimal       @db.Decimal(12, 2)
  description    String?
  paymentMethod  PaymentMethod @default(CASH)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  dailyClosing DailyClosing    @relation(fields: [dailyClosingId], references: [id], onDelete: Cascade)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  attachments  ExpenseAttachment[]

  @@map("expense_entries")
}

model ExpenseAttachment {
  id             String   @id @default(cuid())
  expenseEntryId String
  fileName       String
  fileUrl        String
  fileSize       Int?
  mimeType       String?
  uploadedAt     DateTime @default(now())

  expenseEntry ExpenseEntry @relation(fields: [expenseEntryId], references: [id], onDelete: Cascade)

  @@map("expense_attachments")
}

// ─── ÇALIŞANLAR ──────────────────────────────────────────────────────────────

model Employee {
  id                String     @id @default(cuid())
  userId            String?    @unique
  name              String
  phone             String?
  email             String?
  nationalId        String?
  startDate         DateTime?  @db.Date
  endDate           DateTime?  @db.Date
  isActive          Boolean    @default(true)
  notes             String?
  avatarUrl         String?
  salaryType        SalaryType @default(MONTHLY)
  currentSalary     Decimal    @default(0) @db.Decimal(12, 2)
  dailyMealRate     Decimal    @default(0) @db.Decimal(12, 2)
  defaultTipEnabled Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  user                User?                        @relation("UserEmployee", fields: [userId], references: [id])
  businessAssignments EmployeeBusinessAssignment[]
  salaryHistory       SalaryHistory[]
  attendanceRecords   AttendanceRecord[]

  @@map("employees")
}

model EmployeeBusinessAssignment {
  id         String   @id @default(cuid())
  employeeId String
  businessId String
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([employeeId, businessId])
  @@map("employee_business_assignments")
}

model SalaryHistory {
  id            String     @id @default(cuid())
  employeeId    String
  salaryType    SalaryType
  amount        Decimal    @db.Decimal(12, 2)
  effectiveDate DateTime   @db.Date
  notes         String?
  createdAt     DateTime   @default(now())
  createdBy     String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salary_history")
}

// ─── PUANTAJ ─────────────────────────────────────────────────────────────────

model AttendanceRecord {
  id              String     @id @default(cuid())
  employeeId      String
  businessId      String
  date            DateTime   @db.Date
  shiftType       ShiftType  @default(FULL_DAY)
  hoursWorked     Decimal?   @db.Decimal(5, 2)
  salaryType      SalaryType @default(DAILY)
  dailyRate       Decimal?   @db.Decimal(12, 2)
  hourlyRate      Decimal?   @db.Decimal(12, 2)
  calculatedPay   Decimal?   @db.Decimal(12, 2)
  mealIncluded    Boolean    @default(false)
  mealAmount      Decimal?   @db.Decimal(12, 2)
  tipIncluded     Boolean    @default(false)
  tipAmount       Decimal?   @db.Decimal(12, 2)
  bonusAmount     Decimal?   @db.Decimal(12, 2)
  deductionAmount Decimal?   @db.Decimal(12, 2)
  netPay          Decimal?   @db.Decimal(12, 2)
  notes           String?
  enteredById     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  employee  Employee  @relation(fields: [employeeId], references: [id])
  business  Business  @relation(fields: [businessId], references: [id])
  enteredBy User      @relation(fields: [enteredById], references: [id])

  @@map("attendance_records")
}

// ─── YEMEK SİPARİŞİ ──────────────────────────────────────────────────────────

model MealOrder {
  id          String   @id @default(cuid())
  businessId  String
  date        DateTime @db.Date
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  description String?
  enteredById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  business  Business @relation(fields: [businessId], references: [id])
  enteredBy User     @relation(fields: [enteredById], references: [id])

  @@map("meal_orders")
}

// ─── SİSTEM AYARLARI ─────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  group     String?  @default("general")
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}

// ─── AKTİVİTE LOGU ───────────────────────────────────────────────────────────

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String
  action      LogAction
  entityType  String
  entityId    String?
  businessId  String?
  description String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user     User      @relation("UserLogs", fields: [userId], references: [id])
  business Business? @relation(fields: [businessId], references: [id])

  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}
